# @0625chopin 스코프는 GitHub Packages (발행 후 소비 시 사용).
# 로컬 개발은 package.json의 file:../almbam-shared 링크를 사용하므로 토큰 불필요.
# 발행 버전 소비 전환 시(Vercel/CI 빌드) 아래 스코프 레지스트리 + NPM_TOKEN(read:packages)이 필요하다.
@0625chopin:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NPM_TOKEN}

# file:../almbam-shared 를 심볼릭 링크가 아닌 물리적 복사본으로 설치.
# (심링크 시 Turbopack이 shared 의 exports 서브패스(/ui/*, /common/*)를 해석하지 못해 빌드 실패)
install-links=true
